# ═══════════════════════════════════════════
# OpenClaw Memory DL - 环境变量
# ═══════════════════════════════════════════
# ⚠️ 安全提醒：部署前必须修改所有默认密码！
# ⚠️ 如果端口映射到公网，默认密码等于裸奔。
# cp .env.example .env  然后逐项修改

# ─── 时区 ───
TZ=Asia/Shanghai

# ─── Memos ───
MEMOS_PORT=5230
# Memos 管理员 token (首次启动后在 Memos UI 中创建并获取)
MEMOS_TOKEN=your-memos-token-here

# ─── MySQL ───
MYSQL_PORT=3306
MYSQL_DATABASE=openclaw_business
MYSQL_USER=openclaw
# ⚠️ 必须修改：不要用默认值
MYSQL_PASSWORD=your_strong_password_here
MYSQL_ROOT_PASSWORD=your_strong_root_password_here

# ─── Adminer (可选, MySQL Web UI) ───
ADMINER_PORT=8080

# ─── RAG / 向量库 ───
# LanceDB 路径 (相对于工作区)
LANCEDB_PATH=./semantic_index
# 嵌入模型
EMBEDDING_MODEL=BAAI/bge-m3
# HuggingFace 镜像 (国内加速)
HF_ENDPOINT=https://hf-mirror.com
# 向量维度 (bge-m3 = 1024)
VECTOR_DIM=1024

# ─── 重排序 (可选, 需要 GPU 或较大内存) ───
RERANKER_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ─── 混合检索权重 ───
VECTOR_WEIGHT=0.6
KEYWORD_WEIGHT=0.4

# ─── 块大小 (文本分割) ───
CHUNK_SIZE=500
CHUNK_OVERLAP=50
